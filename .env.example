# Weed Detection API Configuration

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Model Settings
# Options: google/owlv2-base-patch16-ensemble (default, balanced)
#          google/owlv2-large-patch14-ensemble (more accurate, slower)
MODEL_NAME=google/owlv2-base-patch16-ensemble

# Device: cuda, mps (Apple Silicon), or cpu
# Leave empty for auto-detection
DEVICE=

# Detection threshold (0-1, lower = more detections but more false positives)
DEFAULT_CONFIDENCE_THRESHOLD=0.1

# Storage paths
REFERENCE_IMAGES_DIR=data/references
UPLOADS_DIR=data/uploads

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600
